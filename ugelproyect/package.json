{
  "name": "vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js --host 0.0.0.0",
    "dev:tunnel": "node --max-old-space-size=4096 node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "tsc && vite build",
    "lint": "eslint --fix",
    "preview": "vite preview --host 0.0.0.0",
    "tunnel": "node scripts/ngrok.js",
    "ngrok": "node scripts/ngrok.js",
    "start:ngrok": "powershell -ExecutionPolicy Bypass -File start-ngrok.ps1",
    "kill:ngrok": "powershell -ExecutionPolicy Bypass -File kill-ngrok.ps1",
    "kill-port": "powershell -ExecutionPolicy Bypass -File kill-port.ps1",
    "clean": "powershell -ExecutionPolicy Bypass -File kill-port.ps1 && npm run dev",
    "get-ip": "powershell -ExecutionPolicy Bypass -File get-ip.ps1",
    "firewall-allow": "powershell -ExecutionPolicy Bypass -File firewall-allow.ps1"
  },
